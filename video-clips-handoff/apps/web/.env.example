# AUTH
AUTH_SECRET=vcf-clips-dev-secret-change-in-production

# OpenAI (Whisper + GPT) — required for real clip generation
OPENAI_API_KEY=

# Clip worker
WORKER_URL=http://localhost:8787
WORKER_WEBHOOK_SECRET=dev-worker-secret
APP_URL=http://localhost:3010

# Optional R2 (falls back to local filesystem when unset)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=video-clips-media
# R2_PUBLIC_BASE_URL=

# Google Drive OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3010/api/auth/google/callback
